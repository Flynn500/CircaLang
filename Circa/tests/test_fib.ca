fn fib(n) {
    if n <= 1.0 {
        return n
    }

    let a = 0.0
    let b = 1.0
    let i = 2.0

    loop {
        if i > n { break }

        let temp = a + b
        a = b
        b = temp

        i = i + 1.0
    }

    return b
}


let fib_target = 10

let a = 0
let b = 1
let i = 0

loop {
    if i > fib_target { break }

    let temp = a + b
    a = b
    b = temp

    i = i + 1
}
print(b)