// Integrate x² from 0 to 3
// True answer = 9.0
// Error ≈ 1/n², so n ≈ 1/sqrt(tol)

fn square(x) {
    return x * x
}

fn integrate_square(a, b) ~tol {
    let n_float = 1.0 / tol
    let h = (b - a) / n_float
    let sum = (square(a) + square(b)) / 2.0
    let i = 1.0

    loop {
        if i >= n_float { break }
        sum = sum + square(a + i * h)
        i = i + 1.0
    }

    return sum * h
}


let approx = integrate_square(0.0, 3.0) ~ 0.1
print(approx)

let precise = integrate_square(0.0, 3.0) ~ 0.001
print(precise)