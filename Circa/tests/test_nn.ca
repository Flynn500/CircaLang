// Tiny "network" with 2 inputs and 2 hidden neurons (scalar version)

// Inputs with uncertainty
let x1 = 1.0 ~= 0.05
let x2 = 0.5 ~= 0.02

// Hidden layer weights and biases (scalar)
let w11 = 0.5 ~= 0.01
let w12 = -0.3 ~= 0.02
let w21 = 0.8 ~= 0.01
let w22 = 0.2 ~= 0.01
let b1 = 0.0 ~= 0.005
let b2 = 0.1 ~= 0.005

// Output layer weights and bias (scalar)
let v1 = 0.4 ~= 0.01
let v2 = -0.6 ~= 0.01
let c = 0.0 ~= 0.005

// ReLU function
fn relu(x) {
    return max(0.0, x)
}

// Forward pass (scalar)
let h1 = relu(x1*w11 + x2*w21 + b1)
let h2 = relu(x1*w12 + x2*w22 + b2)
let y_hat = h1*v1 + h2*v2 + c

print(y_hat)