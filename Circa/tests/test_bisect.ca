//example of writting tolerance aware functions. generally you would just 
//write standard functions and allow tolerance to propogate, requesting 
//for operations at a certain tolerance via our standard lib. But here
//is how you might construct a basic root finding function.

fn square_minus_two(x) {
    return (x * x) - 2.0
}

//~ after function which promises result within tol
fn find_root(f, lo, hi) ~tol {
    let mid = (lo + hi) / 2.0

    let current_error_margin = (hi - lo) / 2.0

    if current_error_margin <= tol {
        return mid
    }

    if f(lo) * f(mid) > 0.0 {
        // root is NOT between lo and mid → discard lo
        return find_root(f, mid, hi) ~ tol
    } else {
        // root is between lo and mid
        return find_root(f, lo, mid) ~ tol
    }
}

let rough = find_root(square_minus_two, 0.0, 2.0) ~ 0.1
print(rough)

let exact = find_root(square_minus_two, 0.0, 2.0) ~ 0.001
print(exact)


//std lib versions, they account for input tolerance, much more rigouros
let rough = solve(square_minus_two, 0.0, 2.0) ~ 0.1
print(rough)

let exact = solve(square_minus_two, 0.0, 2.0) ~ 0.001
print(exact)

